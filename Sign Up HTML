<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sign up · MK Time</title>
  <meta name="description" content="Create your MK Time account to follow orders and save your preferences.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Source+Sans+3:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="styles/styles.css">
</head>
<body>
  <div class="page-shell">
    <div class="top-bar">Crafted in Edinburgh · Swiss movements · After-sales care</div>

    <header class="site-header">
      <div class="header-inner">
        <a href="index.html" class="logo">MK <span>Time</span></a>
        <nav aria-label="Main navigation">
          <ul class="nav-main">
            <li><a href="index.html">Home</a></li>
            <li><a href="products.html">Watches</a></li>
            <li><a href="signup.html">Sign up</a></li>
            <li><a href="login.html">Log in</a></li>
          </ul>
        </nav>
      </div>
    </header>

    <main class="auth-layout">
      <div class="auth-box">
        <h1>Create an account</h1>
        <p class="auth-sub">
          Register to track orders and save your preferences.
        </p>
        <form action="signup-thanks.html" method="post">
          <div class="form-group">
            <label for="signup-nom">Full name</label>
            <input type="text" id="signup-nom" name="name" autocomplete="name" required>
          </div>
          <div class="form-group">
            <label for="signup-email">Email</label>
            <input type="email" id="signup-email" name="email" autocomplete="email" required>
          </div>
          <div class="form-group">
            <label for="signup-password">Password</label>
            <input type="password" id="signup-password" name="password" autocomplete="new-password" required minlength="8">
          </div>
          <button type="submit" class="btn btn-primary btn-block">Create account</button>
        </form>
        <p class="form-footer">Already have an account? <a href="login.html">Log in</a></p>
      </div>
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <div>
          <div class="footer-brand">MK Time</div>
          <p class="footer-note">Swiss movements · Designed and assembled in Edinburgh, United Kingdom.</p>
        </div>
        <div class="footer-links">
          <a href="index.html">Home</a>
          <a href="products.html">Watches</a>
          <a href="login.html">Log in</a>
        </div>
      </div>
      <p class="copyright">© MK Time · All rights reserved.</p>
    </footer>
  </div>
</body>
</html>
